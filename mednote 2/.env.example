# Copy this file to .env.local and fill in your values

# OpenAI - paste your key here (same one you're using now)
OPENAI_API_KEY=your_openai_api_key_here

# JWT secret - make this a long random string (e.g. type random characters)
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars

# Database path - SQLite file will be created here automatically
DATABASE_PATH=./mednote.db
